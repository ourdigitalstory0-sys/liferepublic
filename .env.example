# Kolte Patil Life Republic - Sovereign Portal Environment Configuration
# ----------------------------------------------------------------------
# This file contains the necessary environment variables for the production
# launch of the Life Republic architectural monograph.

# 1. CORE DATA INFRASTRUCTURE (Supabase)
# Required for project listings, leads management, and blog posts.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# 2. NEURAL INTELLIGENCE (Gemini AI)
# Powers the "Township Agent" (Sovereign Concierge) and dynamic search.
# Obtain from: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key

# 3. SPATIAL ENGINE (Google Maps)
# Powers the "Sector Mesh" and "Connectivity Hub" interactive maps.
# Obtain from: https://console.cloud.google.com/
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# 4. CONVERSION PIPELINE (Email/WhatsApp Fallback)
# Used as a secondary relay for lead notifications.
VITE_CONTACT_EMAIL=sales@life-republic.in
VITE_WHATSAPP_NUMBER=918888888888

# 5. PRODUCTION METRICS
# Set to 'true' to enable high-fidelity debug logging in development.
VITE_DEBUG_MODE=false
VITE_APP_ENV=production
